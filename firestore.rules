rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAuth() { return request.auth != null; }
    function isOwner(uid) { return isAuth() && request.auth.uid == uid; }
    function isParticipant(participants) { return isAuth() && request.auth.uid in participants; }

    // USERS
    match /users/{uid} {
      allow read: if isAuth();
      allow create: if isOwner(uid);
      allow update: if isOwner(uid);
    }

    // POSTS
    match /posts/{postId} {
      allow read: if isAuth();
      allow create: if isAuth() && request.resource.data.authorId == request.auth.uid;
      allow update: if isAuth() && resource.data.authorId == request.auth.uid;
      allow delete: if isAuth() && resource.data.authorId == request.auth.uid;

      match /comments/{commentId} {
        allow read: if isAuth();
        allow create: if isAuth() && request.resource.data.authorId == request.auth.uid;
        allow update: if isAuth() && resource.data.authorId == request.auth.uid;
        allow delete: if isAuth() && resource.data.authorId == request.auth.uid;
      }
    }

    // CONVERSATIONS & MESSAGES
    match /conversations/{convId} {
      allow read: if isAuth() && isParticipant(resource.data.participants);
      allow create: if isAuth() && isParticipant(request.resource.data.participants);
      allow update: if isAuth() && isParticipant(resource.data.participants);

      match /messages/{msgId} {
        allow read: if isAuth() && isParticipant(get(/databases/$(database)/documents/conversations/$(convId)).data.participants);
        allow create: if isAuth() && request.resource.data.senderId == request.auth.uid;
        allow update: if isAuth() && resource.data.senderId == request.auth.uid;
      }
    }

    // CHALLENGES
    match /challenge_invites/{docId} {
      allow read: if isAuth() && (resource.data.challengerId == request.auth.uid || resource.data.targetId == request.auth.uid);
      allow create: if isAuth() && request.resource.data.challengerId == request.auth.uid;
      allow update: if isAuth() && (resource.data.challengerId == request.auth.uid || resource.data.targetId == request.auth.uid);
    }

    match /challenge_completions/{docId} {
      allow read: if isAuth() && resource.data.userId == request.auth.uid;
      allow create: if isAuth() && request.resource.data.userId == request.auth.uid;
    }

    // LAGA
    match /laga_requests/{docId} {
      allow read: if isAuth() && (resource.data.requesterId == request.auth.uid || resource.data.targetId == request.auth.uid);
      allow create: if isAuth() && request.resource.data.requesterId == request.auth.uid;
      allow update: if isAuth() && (resource.data.requesterId == request.auth.uid || resource.data.targetId == request.auth.uid);
    }

    // FOLLOWERS
    match /followers/{userId}/items/{followerId} {
      allow read: if isAuth();
      allow create: if isAuth() && request.auth.uid == followerId;
      allow delete: if isAuth() && request.auth.uid == followerId;
    }

    // FRIENDS
    match /friends/{userId}/items/{friendId} {
      allow read: if isAuth();
    }

    // FRIEND REQUESTS
    match /friend_requests/{userId}/items/{requesterId} {
      allow read: if isAuth() && request.auth.uid == userId;
      allow create: if isAuth() && request.auth.uid == requesterId;
      allow delete: if isAuth() && (request.auth.uid == userId || request.auth.uid == requesterId);
    }

    // NOTIFICATIONS
    match /notifications/{userId}/items/{notifId} {
      allow read: if isOwner(userId);
      allow create: if isAuth();
      allow update: if isOwner(userId);
      allow delete: if isOwner(userId);
    }

    // ACHIEVEMENTS
    match /achievements/{achievementId} {
      allow read: if isAuth();
    }

    match /userAchievements/{userId}/items/{achievementId} {
      allow read: if isAuth();
    }

    // BLOCK ALL OTHER
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
